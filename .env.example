# 文心大模型 API 配置（AI Studio token）
ERNIEBOT_ACCESS_TOKEN=你的token

# 强模型 token（可选，为空则与上面共用）
ERNIEBOT_STRONG_TOKEN=

# 模型配置（可选，有默认值）
MODEL_LITE=ernie-lite
MODEL_STRONG=ernie-3.5

# MCP 服务器配置（可选）
# MCP_SERVER_PORT=8765

# Worker 配置
# WORKER_HEARTBEAT_INTERVAL=10

# 安全配置（可选）
# CONFIRM_TIMEOUT=30

# 日志级别
# LOG_LEVEL=INFO
